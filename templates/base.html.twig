<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <title>{% block title %}Bisounours{% endblock %}</title>
        <link rel= "stylesheet" href="https://bootswatch.com/5/flatly/bootstrap.min.css">
        {% block stylesheets %} {% endblock %}
    </head>
        <head>
    <style type="text/css">
    table, caption, th, td {

    border: 2px solid skyblue;
    border-collapse: collapse;

    }
    caption, th, td {

    padding: 8px;

    }

    th {

    background-color: gray;

    }

    </style>
    </head>
    <body>


    
<nav class="navbar navbar-expand-lg navbar-dark bg-primary">
  <div class="container-fluid">
    <a class="navbar-brand" href="/">
			<img loading="lazy" width="35" src="{{ asset('https://media.discordapp.net/attachments/968955109155418132/1066347353130410045/588a666dd06f6719692a2d18.png') }}" />
		</a>
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarColor01" aria-controls="navbarColor01" aria-expanded="false" aria-label="Toggle navigation">

		<!-- Brand -->

		<!-- Toggler -->
		<button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarCollapse" aria-controls="navbarCollapse" aria-expanded="false" aria-label="Toggle navigation">
			<span class="navbar-toggler-icon"></span>
		</button>

		<!-- Collapse -->
		<div class="collapse navbar-collapse" id="navbarCollapse">

			<!-- Toggler -->
			<button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarCollapse" aria-controls="navbarCollapse" aria-expanded="false" aria-label="Toggle navigation">
				<i class="fe fe-x"></i>
			</button>

			<!-- Navigation -->
			<ul class="navbar-nav ms-auto">
				<li class="nav-item dropdown">
					<a href="/portfolio" class="nav-link">Portfolio</a>
				</li>
				<li class="nav-item dropdown">
					<a href="/cv" class="nav-link">CV</a>
			</ul>

			<!-- Button -->
			<a class="navbar-btn btn btn-sm btn-primary lift ms-auto" href="/contact">
				Me contacter
			</a>

		</div>

	</div>
</nav>

        <div class="container">
        {% block body %}{% endblock %}
        
        </div>
        {% block javascripts %}{% endblock %}
        
    </body>
		
    <!-- FOOTER -->
<footer class="py-8 py-md-11 bg-dark">
	<div class="container">
		<div class="row">
			<div class="col-12 col-md-4 col-lg-3">
            

				<!-- Brand -->
				<img loading="lazy" width="30" src="{{ asset('https://media.discordapp.net/attachments/968955109155418132/1066360696494895135/1200px-Copyright.svg.png?width=639&height=639') }}" />

				<!-- Text -->
				<p class="text-gray-700 mb-2">
				</p>
			</div>
            

			<div class="col-12 col-md-4 col-lg-2">

				<!-- Heading -->
				<h6 class="fw-bold text-uppercase text-gray">
					Menu
				</h6>

				<!-- List -->
				<ul class="list-unstyled text-black mb-6 mb-md-8 mb-lg-0">
					<li class="mb-2">
						<a href="/portfolio" class="text-reset">
							Mon Portfolio
						</a>
					</li>
					<li class="mb-2">
						<a href="/cv" class="text-reset">
							Mon CV
						</a>
					</li>
					<li>
						<a href="/contact" class="text-reset">
							Me contacter
						</a>
					</li>
				</ul>

			</div>
		<!-- / .row -->
	</div>
	<!-- / .container -->
</footer>
    
</html>
